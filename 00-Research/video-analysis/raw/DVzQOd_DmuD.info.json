_ht=scontent-atl3-2.cdninstagram.com&_nc_ohc=x2ehYxss4GUQ7kNvwF0LIVL&%3D%3D&ccb=17-1&_nc_gid=Htjpb0P-hrI8PLZIzPHt9g&_nc_zt=28&_nc_ss=7a32e&oh=00_Af2ri99nf5aBAL69voRWbXAyFaycw1zDT24QA95qQ7jNTg&oe=69D301CF", "manifest_stream_number": 0, "is_dash_periods": true, "protocol": "https", "video_ext": "mp4", "audio_ext": "none", "abr": 0, "vbr": 1541.767, "resolution": "1080x1920", "aspect_ratio": 0.56, "filesize_approx": 12503152, "http_headers": {"User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/143.0.0.0 Safari/537.36", "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8", "Accept-Language": "en-us,en;q=0.5", "Sec-Fetch-Mode": "navigate", "Referer": "https://www.instagram.com/"}, "format": "dash-1623047032226821v - 1080x1920 (DASH video)"}], "title": "Video by __diditee__", "description": "This is How To Get 3D Tracking Title Cards On Your Phone!\n\nComment the word “BANANA” 🍌 to get my 3D reference pack and prompts\n\nHere’s how you do it 👇\n\n1️⃣ Film a video of you holding an object.\nScreenshot the first frame of the video.\n\n2️⃣ Head to Higgsfield.ai → Create → Images → Nano Banana Pro.\nUpload your screenshot and one of the reference images from my 3D reference pack.\n\n3️⃣ Paste this prompt and customise the text however you like.\n\nCreate a 3D text anchored to the [object] in the image.\nUse the text graphic from the camera photo as reference.\nThe text should say [your custom title].\n\n4️⃣ Choose 4 generations and hit generate.\nDownload your favourite result.\n\n5️⃣ To animate it, go to Create → Videos → Create Video.\nChange the model to Kling 3.0 Omni.\nUpload the plain screenshot as the start frame and the generated image as the end frame.\nPaste in the animation prompt and generate.\n\n6️⃣ To track the text, go to Kling 3.0 Omni Edit.\nUpload your full video, along with the plain screenshot and the generated image.\n\n7️⃣ Paste in the tracking prompt and hit generate.\n\nVoila!\nYou now have 3D tracking title cards with no VFX experience needed.\n\nLike and follow for more!\n@higgsfield.ai \n\n#filmmaking #editing #videography #tutorial #higgsfield", "duration": 64.877, "timestamp": 1773354585, "uploader_id": "304884398", "uploader": "Declann Drostan Tan | Content Creator", "channel": "__diditee__", "like_count": 22820, "comment_count": 13629, "comments": [{"author": "_benhair", "author_id": "2179147384", "id": "17907715773203780", "text": "Banana", "timestamp": 1775054964}, {"author": "ahmedh.ghopashy", "author_id": "76095646154", "id": "18073319561216007", "text": "Banana", "timestamp": 1775054122}, {"author": "nafees_rabbani", "author_id": "2492848713", "id": "18077073761412130", "text": "Banana", "timestamp": 1775053687}, {"author": "mrgaylan", "author_id": "2039474943", "id": "18090288160913689", "text": "banana", "timestamp": 1775051119}, {"author": "mura_shot", "author_id": "44504542158", "id": "18082426883346088", "text": "Banana", "timestamp": 1775049930}], "thumbnails": [{"url": "https://scontent-atl3-3.cdninstagram.com/v/t51.82787-15/650376902_18567090034052399_3115773899979757447_n.jpg?stp=dst-jpg_e35_p640x640_sh0.08_tt6&efg=eyJ2ZW5jb2RlX3RhZyI6ImltYWdlX3VybGdlbi4zMDcweDU0NjIuc2RyLmY4Mjc4Ny5kZWZhdWx0X2NvdmVyX2ZyYW1lLmMyIn0&_nc_ht=scontent-atl3-3.cdninstagram.com&_nc_cat=111&_nc_oc=Q6cZ2gF21-V360aONRQByNs8L-M2kOGtDYmvyU_1Zn3k7UHmimKag6sz3zscpzL99h2xKag&_nc_ohc=CdWik3DtE7kQ7kNvwH8TVyM&_nc_gid=Htjpb0P-hrI8PLZIzPHt9g&edm=ANTKIIoBAAAA&ccb=7-5&oh=00_Af1gmL8ThtiVxZR7LD1LPftLgq4ZWk2pkdB-v1qDtnMWIA&oe=69D2FE89&_nc_sid=d885a2", "width": 640, "height": 1138, "id": "0", "resolution": "640x1138"}, {"url": "https://scontent-atl3-3.cdninstagram.com/v/t51.82787-15/650376902_18567090034052399_3115773899979757447_n.jpg?stp=dst-jpg_e35_p750x750_sh0.08_tt6&efg=eyJ2ZW5jb2RlX3RhZyI6ImltYWdlX3VybGdlbi4zMDcweDU0NjIuc2RyLmY4Mjc4Ny5kZWZhdWx0X2NvdmVyX2ZyYW1lLmMyIn0&_nc_ht=scontent-atl3-3.cdninstagram.com&_nc_cat=111&_nc_oc=Q6cZ2gF21-V360aONRQByNs8L-M2kOGtD